# Backend
ENV=development
DATABASE_URL=sqlite:///./data/medbridge.db
SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256
FRONTEND_URLS=http://localhost:8501,http://localhost:8502

# Frontends
BACKEND_URL=http://127.0.0.1:8000
PATIENT_PORTAL_URL=http://localhost:8501
DOCTOR_PORTAL_URL=http://localhost:8502

# AI Providers
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Deployment note:
# For free hosting, prefer Supabase Postgres for DATABASE_URL.
# Local uploads and Chroma data under ./data remain ephemeral on free Render.
